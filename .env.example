# ========================================================================
# VSBS — Autonomous Vehicle Service Booking System
# .env.example — copy to .env and fill in real values.
#
# INVARIANT: every subsystem with a "_MODE" toggle below is backed by
# an adapter whose sim and live drivers implement the IDENTICAL state
# machine. Promotion from sim to live is flipping the toggle only.
# Nothing else changes. See docs/simulation-policy.md.
# ========================================================================

# --- Environment ---
NODE_ENV=development
LOG_LEVEL=info
# Demo mode surfaces a persistent AAA-contrast banner on every page in
# sim mode. Flip to false for production.
APP_DEMO_MODE=true

# Dual-region deployment: India first, US second. Each is fully isolated
# for data residency (DPDP India, CCPA/CPRA US).
APP_REGIONS=asia-south1,us-central1
APP_PRIMARY_REGION=asia-south1
APP_PRIMARY_LOCALE=en
APP_SUPPORTED_LOCALES=en,hi,ta,te,bn,mr,gu,kn,ml,pa

# --- LLM layer (provider-agnostic, packages/llm) ---
# Profile picks the (provider, model) for every agent role:
#   demo → Google AI Studio Gemini 2.5 Flash-Lite everywhere (cheapest,
#          free tier, zero GCP setup needed for local dev).
#   prod → Vertex AI Claude Opus 4.6 + Gemini 3 Pro/Flash + Claude Haiku
#          4.5, all authenticated via Workload Identity in
#          dmjone. No ANTHROPIC_API_KEY required.
# Switching is a single flip; prompts, tools, LangGraph topology invariant.
LLM_PROFILE=demo

# Per-role override example (any role can deviate from the profile):
#   LLM_CONCIERGE_PROVIDER=openai
#   LLM_CONCIERGE_MODEL=gpt-5
#   LLM_VERIFIER_PROVIDER=vertex-gemini
#   LLM_VERIFIER_MODEL=gemini-3-flash

# --- AI safety: pinned model versions per role ---
# Demo and prod profiles FAIL FAST on startup if any role's pin is missing.
# Sim profile uses scripted-1@1.0.0 deterministically and ignores these.
# Format: <provider>:<modelId>@<version>[#<cap1>,<cap2>...]
#   provider ∈ google-ai-studio | vertex-gemini | vertex-claude | anthropic | openai | scripted
#   capabilities ∈ tool-use | deterministic-format | long-context | india-locale | low-cost | high-stakes
# VSBS_MODEL_PIN_CONCIERGE=vertex-claude:claude-opus-4-6@2026-04-01#tool-use,high-stakes
# VSBS_MODEL_PIN_INTAKE=vertex-gemini:gemini-3-flash@2026-04-01#tool-use,india-locale
# VSBS_MODEL_PIN_DIAGNOSIS=vertex-claude:claude-opus-4-6@2026-04-01#tool-use,high-stakes
# VSBS_MODEL_PIN_DISPATCH=vertex-gemini:gemini-3-pro@2026-04-01#tool-use
# VSBS_MODEL_PIN_WELLBEING=vertex-gemini:gemini-3-flash@2026-04-01#low-cost
# VSBS_MODEL_PIN_VERIFIER=vertex-claude:claude-haiku-4-5-20251001@2025-10-01#deterministic-format,low-cost
# VSBS_MODEL_PIN_AUTONOMY=vertex-claude:claude-opus-4-6@2026-04-01#high-stakes
# VSBS_MODEL_PIN_PAYMENT=vertex-claude:claude-haiku-4-5-20251001@2025-10-01#deterministic-format

# --- AI safety: canary router ---
# Percent of conversations to send to a candidate model. 0 disables canary.
# Routing is deterministic per conversationId.
AGENT_CANARY_PERCENT=0
# Optional salt — change to re-shuffle without rotating model ids.
AGENT_CANARY_SALT=

# --- AI safety: agent memory ---
# Default scope for any new memory write. Promotion to wider scopes
# (vehicle/owner) requires an explicit promote() call with reason.
AGENT_MEMORY_DEFAULT_SCOPE=conversation

# --- Provider credentials (only the ones you use) ---
# Demo default — free tier at https://aistudio.google.com/app/apikey
GOOGLE_AI_STUDIO_API_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# Anthropic direct API (optional — only for Managed Agents beta or
# Anthropic-direct billing; vertex-claude does not need this).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_OPUS=claude-opus-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MANAGED_AGENTS_BETA=managed-agents-2026-04-01

# --- Google Cloud / Vertex AI ---
# Project used for all Google APIs for this codebase.
GOOGLE_CLOUD_PROJECT=dmjone
GOOGLE_CLOUD_REGION=asia-south1
GOOGLE_CLOUD_REGION_SECONDARY=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_AI_LOCATION=asia-south1
# Gemini 2.5 retires 2026-10-16; default to Gemini 3 Pro.
VERTEX_GEMINI_MODEL=gemini-3-pro
# Gemini Live API (GA on Vertex) for native audio voice intake.
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio

# --- Google Maps Platform (keys provisioned in GOOGLE_CLOUD_PROJECT) ---
MAPS_BROWSER_API_KEY=
MAPS_SERVER_API_KEY=
# Toggle: sim uses an in-process deterministic driver that implements
# the same state machine as the live Routes API adapter.
MAPS_MODE=sim

# --- Firestore / Identity Platform ---
FIRESTORE_DATABASE_ID=(default)
IDENTITY_PLATFORM_TENANT=

# --- AlloyDB (repair KG + vector) ---
ALLOYDB_INSTANCE_URI=
ALLOYDB_DB=vsbs_kb
ALLOYDB_USER=vsbs
ALLOYDB_PASSWORD_SECRET=projects/dmjone/secrets/alloydb-password/versions/latest

# --- Auth (OTP) ---
# Demo mode: OTP is generated server-side AND returned in the response
# for live display on the UI. No SMS is dispatched. For the real system,
# flip AUTH_MODE=live and set TWILIO_*/MSG91_* or a local SMS gateway.
AUTH_MODE=sim
AUTH_OTP_LENGTH=6
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_LOCKOUT_SECONDS=900
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
# MSG91 is the common India fallback.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# --- Connected-car ---
# Smartcar covers the US / EU / CA; India and many 2W markets need our
# own BLE OBD-II dongle gateway. Adapter interface is the same.
SMARTCAR_CLIENT_ID=
SMARTCAR_CLIENT_SECRET=
SMARTCAR_REDIRECT_URI=
SMARTCAR_MODE=sim
OBD_DONGLE_MODE=sim

# --- NHTSA vPIC (free, no key) ---
NHTSA_VPIC_BASE=https://vpic.nhtsa.dot.gov/api/vehicles

# --- India RC lookup ---
INDIA_RC_PROVIDER=none # none | surepass | signzy | karza | perfios
INDIA_RC_API_KEY=

# --- Payments ---
# Sim mode implements the full order → intent → authorise → capture →
# settle → webhook state machine deterministically. Promotion to live is
# a single toggle, no logic change. See docs/simulation-policy.md.
PAYMENT_MODE=sim
PAYMENT_PROVIDER=razorpay # razorpay | stripe | upi
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# UPI PSP is routed through Razorpay or Cashfree in live mode; the sim
# driver reproduces the VPA validate → collect → callback flow.
UPI_VPA=
UPI_PSP=razorpay

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=https://telemetry.googleapis.com
OTEL_SERVICE_NAME=vsbs-api
SENTRY_DSN=

# --- Realtime escalation (optional) ---
ABLY_API_KEY=

# --- Security ---
SESSION_COOKIE_NAME=__Host-vsbs-session
SESSION_COOKIE_MAX_AGE=1800
CSP_REPORT_URI=/api/_/csp-report
RECAPTCHA_ENTERPRISE_SITE_KEY=
RECAPTCHA_ENTERPRISE_PROJECT=dmjone

# On-device PII redaction (faces / plates) before photo upload. The
# detector model file is fetched from this path; a 404 keeps the
# detector not-ready and uploadPhoto() refuses to send. See
# apps/web/src/lib/redaction.ts.
NEXT_PUBLIC_REDACTION_DETECTOR_URL=/models/face-detector-quant.onnx
NEXT_PUBLIC_REDACTION_PLATE_DETECTOR_URL=/models/plate-detector-quant.onnx

# Differential-privacy budget for on-device analytics. ε is spent per
# flush; once the session budget is exhausted, no more aggregates are
# beaconed. See apps/web/src/lib/analytics.ts.
ANALYTICS_DP_EPSILON=1.0
ANALYTICS_DP_K=5
ANALYTICS_DP_SESSION_BUDGET=2.0

# Release signing — sigstore/cosign keyless via GitHub Actions OIDC.
# This variable is consumed by .github/workflows/release.yml; override
# only when self-hosting or using a non-keyless KMS-backed key. The
# default empty value selects keyless OIDC.
RELEASE_COSIGN_KEY_REF=

# --- Autonomy ---
AUTONOMY_ENABLED=false
AUTONOMY_MODE=sim
AUTONOMY_TIER_A_AVP_PROVIDERS=apcoa-stuttgart-p6
AUTONOMY_MAX_GRANT_SECONDS=21600
AUTONOMY_DEFAULT_AUTOPAY_CAP_INR=0
AUTONOMY_DEFAULT_AUTOPAY_CAP_USD=0

# Mercedes-Benz + Bosch Intelligent Park Pilot (AVP Tier A) adapter.
# Sim walks the Stuttgart APCOA P6 flow deterministically. Live requires
# both the base URL and a bearer token; construction fails fast otherwise.
MERCEDES_IPP_MODE=sim
MERCEDES_IPP_BASE=
MERCEDES_IPP_TOKEN=

# --- Sensors ---
# mixed = real where connected, sim for everything else. Every sim
# sample carries origin: "sim" and cannot enter real decision logs.
SENSORS_MODE=mixed

# --- STT / Voice ---
STT_MODE=sim

# --- Feature flags ---
FEATURE_VOICE_INTAKE=true
FEATURE_SIMULATED_SENSORS=true
FEATURE_PHM=true
FEATURE_AUTONOMY_DASHBOARD=true
