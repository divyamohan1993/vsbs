{
  "name": "@vsbs/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "test": "vitest run",
    "test:agent-eval": "vitest run --config vitest.eval.config.ts"
  },
  "dependencies": {
    "@vsbs/shared": "workspace:*",
    "@vsbs/llm": "workspace:*",
    "@vsbs/security": "workspace:*",
    "@langchain/langgraph": "^0.2.74",
    "@langchain/core": "^0.3.40",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^4.1.5",
    "@biomejs/biome": "^2.4.14"
  }
}
