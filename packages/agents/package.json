{
  "name": "@vsbs/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "test": "vitest run",
    "test:agent-eval": "vitest run --config vitest.eval.config.ts"
  },
  "dependencies": {
    "@vsbs/shared": "workspace:*",
    "@vsbs/llm": "workspace:*",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/core": "^1.1.42",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.0",
    "@biomejs/biome": "^1.9.4"
  }
}
