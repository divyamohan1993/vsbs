{
  "name": "@vsbs/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "start": "bun src/server.ts",
    "build": "bun build ./src/server.ts --target=bun --outdir=dist --minify",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "test": "vitest run"
  },
  "dependencies": {
    "@vsbs/shared": "workspace:*",
    "@vsbs/sensors": "workspace:*",
    "@vsbs/llm": "workspace:*",
    "@vsbs/agents": "workspace:*",
    "hono": "^4.6.10",
    "@hono/zod-validator": "^0.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4",
    "@biomejs/biome": "^2.4.12"
  }
}
