{
  "expo": {
    "name": "VSBS Owner",
    "slug": "vsbs-owner",
    "owner": "dmj-one",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vsbs",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0d12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "one.dmj.vsbs.owner",
      "infoPlist": {
        "NSCameraUsageDescription": "VSBS uses your camera to capture photos of warning lights and visible damage so we can diagnose your vehicle.",
        "NSMicrophoneUsageDescription": "VSBS uses your microphone to record engine and brake noise for diagnostic analysis.",
        "NSBluetoothAlwaysUsageDescription": "VSBS connects to OBD-II Bluetooth dongles to read live diagnostic data from your vehicle.",
        "NSBluetoothPeripheralUsageDescription": "VSBS connects to OBD-II Bluetooth dongles to read live diagnostic data from your vehicle.",
        "NSFaceIDUsageDescription": "VSBS uses Face ID to sign command grants that let the service centre move your vehicle on your behalf.",
        "NSLocationWhenInUseUsageDescription": "VSBS uses your location to dispatch the nearest service centre and to validate command-grant geofences.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": ["applinks:vsbs.dmj.one", "webcredentials:vsbs.dmj.one"]
    },
    "android": {
      "package": "one.dmj.vsbs.owner",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0d12"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "vsbs.dmj.one" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-camera",
        { "cameraPermission": "VSBS uses the camera to capture diagnostic photos." }
      ],
      [
        "expo-notifications",
        {
          "color": "#5a8dee",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "extra": {
      "apiBaseDefault": "https://api.vsbs.dmj.one",
      "apiBaseIN": "https://api-asia-south1.vsbs.dmj.one",
      "apiBaseUS": "https://api-us-central1.vsbs.dmj.one",
      "demoApiBase": "http://localhost:8787",
      "router": {
        "origin": false
      }
    }
  }
}
